# Robinhood Chain mainnet. Use a production provider such as Alchemy in hosted
# environments; Robinhood's public endpoint is rate-limited.
NEXT_PUBLIC_RH_RPC=https://rpc.mainnet.chain.robinhood.com

# Audited, network-specific application deployments. Financial actions remain
# locked while any required address is missing or the zero address.
NEXT_PUBLIC_OSR_TOKEN=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_OSR_GAME=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_OSR_VAULT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_OSR_TREASURY=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_XOMX_TOKEN=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_CVXX_TOKEN=0x0000000000000000000000000000000000000000

# Set only after contracts and receipt verification are deployed.
NEXT_PUBLIC_ONCHAIN=0

# Privy authentication and embedded EVM hot wallets. The app ID/client ID are
# public; the app secret and optional verification key are server-only.
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
NEXT_PUBLIC_PRIVY_CLIENT_ID=
PRIVY_APP_SECRET=your-privy-app-secret
PRIVY_JWT_VERIFICATION_KEY=

# Supabase global profiles, activity history, and realtime leaderboards.
# The secret/service-role key is server-only and must never use NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
SUPABASE_SECRET_KEY=sb_secret_YOUR_KEY
